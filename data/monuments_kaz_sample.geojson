{ "type": "Feature", "properties": { "id": 18740, "Primary Name": "Стоянка. Объект № 161", "Primary Name (English)": null, "Other Names": null, "Country": "Казахстан", "Region": "Атырауская область", "Classification": "Археологический памятник", "CAAL_ID": "Mon_KZ_AE2- 000397", "Internal Reference": "KZ_AE_AR-01-62_0-106", "External Reference": null, "Monument Passport": null, "Monument Type1": "Stopping place", "Monument Type2": null, "Monument Type3": null, "Monument Type4": null, "Monument Type5": null, "Monument Type6": null, "Religion1": null, "Religion2": null, "Religion3": null, "Descriptive Date": "XX - IX вв. до н.э.", "Cultural Period1": "БРОНЗОВЫЙ ВЕК", "Cultural Period2": null, "Cultural Period3": null, "Cultural Period4": null, "Cultural Period5": null, "Cultural Period6": null, "Primary Description": "Стоянка расположена на небольшой возвышенности. На поверхности найдены мелкие фрагменты неорнаментированной керамики, изготовленной вручную, и обожжённые кости. Найден один фрагмент, орнаментированный волнистыми линиями.\nК северу от территории памятника расположено два шурфа, в стенке одного из них удалось проследить погребенную почву. Погребенная почва находится на глубине около 0,5 м и представляет собой тёмный гумусированный слой земли мощностью около 0,2-0,25 м.", "Primary Description (English)": null, "Additional Notes": null, "Longitude": 53.659733, "Latitude": 45.902637, "Altitude": null, "Location Confidence": "Высокая", "Location Notes": "Стоянка расположена южнее посёлка Жана Каратон", "Primary Address": null, "Administrative Subdivision Name1": "Атырауская", "Administrative Subdivision Type1": "Область", "Administrative Subdivision Name2": "Жалыойский", "Administrative Subdivision Type2": "Район", "Administrative Subdivision Name3": "Жана Каратон", "Administrative Subdivision Type3": "Округ / сельский административный округ", "Administrative Subdivision Name4": "Жана Каратон", "Administrative Subdivision Type4": "село", "Measurement Value1": "94", "Measurement Unit1": "квадратные метры", "Measurement Type1": "Площадь", "Measurement Value2": "", "Measurement Unit2": null, "Measurement Type2": null, "Measurement Value3": "", "Measurement Unit3": null, "Measurement Type3": null, "Measurement Value4": "", "Measurement Unit4": null, "Measurement Type4": null, "Designation": null, "World Heritage Site Name": null, "Monument is part of": null, "Monument contains": null, "Monument is associated with": null, "Preferred Language": "Russian", "Recorder": "Aleksandr", "MasterID": null, "Tstamp": "2022-07-22T12:34:53.946", "Original Primary Description": null, "Original Additional Notes": null, "Original Location Notes": null, "Date of Recording": "2022-04-22", "Start Date": -2000, "End Date": -900 }, "geometry": { "type": "Point", "coordinates": [ 53.659733, 45.902637 ] } },
