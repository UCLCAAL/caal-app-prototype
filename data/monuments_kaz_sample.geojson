{ "type": "Feature", "properties": { "id": 18740, "Primary Name": "Стоянка. Объект № 161", "Primary Name (English)": null, "Other Names": null, "Country": "Казахстан", "Region": "Атырауская область", "Classification": "Археологический памятник", "CAAL_ID": "Mon_KZ_AE2- 000397", "Internal Reference": "KZ_AE_AR-01-62_0-106", "External Reference": null, "Monument Passport": null, "Monument Type1": "Stopping place", "Monument Type2": null, "Monument Type3": null, "Monument Type4": null, "Monument Type5": null, "Monument Type6": null, "Religion1": null, "Religion2": null, "Religion3": null, "Descriptive Date": "XX - IX вв. до н.э.", "Cultural Period1": "БРОНЗОВЫЙ ВЕК", "Cultural Period2": null, "Cultural Period3": null, "Cultural Period4": null, "Cultural Period5": null, "Cultural Period6": null, "Primary Description": "Стоянка расположена на небольшой возвышенности. На поверхности найдены мелкие фрагменты неорнаментированной керамики, изготовленной вручную, и обожжённые кости. Найден один фрагмент, орнаментированный волнистыми линиями.\nК северу от территории памятника расположено два шурфа, в стенке одного из них удалось проследить погребенную почву. Погребенная почва находится на глубине около 0,5 м и представляет собой тёмный гумусированный слой земли мощностью около 0,2-0,25 м.", "Primary Description (English)": null, "Additional Notes": null, "Longitude": 53.659733, "Latitude": 45.902637, "Altitude": null, "Location Confidence": "Высокая", "Location Notes": "Стоянка расположена южнее посёлка Жана Каратон", "Primary Address": null, "Administrative Subdivision Name1": "Атырауская", "Administrative Subdivision Type1": "Область", "Administrative Subdivision Name2": "Жалыойский", "Administrative Subdivision Type2": "Район", "Administrative Subdivision Name3": "Жана Каратон", "Administrative Subdivision Type3": "Округ / сельский административный округ", "Administrative Subdivision Name4": "Жана Каратон", "Administrative Subdivision Type4": "село", "Measurement Value1": "