{ "type": "Feature", "properties": { "id": 13931, "Primary Name": "Джарынкудук", "Primary Name (English)": "Djarinkuduk", "Other Names": null, "Country": "Узбекистан", "Region": "Каракалпакстан", "Classification": "Археологический памятник", "CAAL_ID": "Mon_UZ_KRKL-000014", "Internal Reference": "Памятник находится на территории Кунградского района", "External Reference": null, "Monument Passport": "Без паспорта", "Monument Type1": "Могильник", "Monument Type2": "Место остановки", "Monument Type3": null, "Monument Type4": null, "Monument Type5": null, "Monument Type6": null, "Religion1": "Анимизм", "Religion2": null, "Religion3": null, "Descriptive Date": "5000-4000", "Cultural Period1": "Ранний мезолит", "Cultural Period2": "НИЖНИЙ ПАЛЕОЛИТ", "Cultural Period3": null, "Cultural Period4": null, "Cultural Period5": null, "Cultural Period6": null, "Primary Description": "Памятник находится на территории плато Устюрта. Большинство стоянок относится к периодам позднего палеолита и мезолита", "Primary Description (English)": "The monument is located on the territory of the Ustyurt plateau. Most of the sites belong to the Late Paleolithic and Mesolithic periods", "Additional Notes": "В составе памятника существуют несколько курганных могильников античного периода", "Longitude": 56.232222, "Latitude": 44.949722, "Altitude": null, "Location Confidence": "Средняя", "Location Notes": "Памятник расположен на территории Кунградского района", "Primary Address": "Кунградский район ССГ Устюрт", "Administrative Subdivision Name1": "Кунград", "Administrative Subdivision Type1": "Район", "Administrative Subdivision Name2": "Устюрт", "Administrative Subdivision Type2": "Округ / сельский административный округ", "Administrative Subdivision Name3": null, "Administrative Subdivision Type3": null, "Administrative Subdivision Name4": null, "Administrative Subdivision Type4": null, "Measurement Value1": "", "Measurement Unit1": null, "Measurement Type1": null, "Measurement Value2": "", "Mea